@echo off
chcp 65001 >nul
REM ============================================
REM  每日数据同步脚本
REM  用法: 双击运行，或添加到 Windows 任务计划程序
REM  每天 15:30 自动运行
REM ============================================

cd /d "%~dp0"

echo.
echo ========================================
echo  股票系统 - 每日数据同步
echo  时间: %date% %time%
echo ========================================
echo.

REM 先尝试从券商客户端同步（秒级，离线）
python -m data.sync --source tdx 2>&1

REM 如果券商客户端没有新数据，再用 AKShare 在线同步最近 3 天
python -m data.sync --source akshare -n 3 2>&1

echo.
echo ========================================
echo  同步完成
echo ========================================
pause
